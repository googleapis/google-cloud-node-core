{
  "$schema": "./node_modules/syncpack/schema.json",
  "versionGroups": [
    {
      "label": "Ignore special specifier types (files, git, etc)",
      "specifierTypes": ["file", "git", "url", "alias", "link", "unsupported", "workspace-protocol"],
      "isIgnored": true
    },
    {
      "label": "Sync production and internal dependencies to the same major version",
      "dependencyTypes": [
        "prod",
        "local"
      ],
      "packages": ["**"],
      "policy": "sameMajor"
    },
    {
      "label": "Ignore all other dependency types",
      "dependencyTypes": ["**"],
      "isIgnored": true
    }
  ],
  "semverGroups": [
    {
      "label": "Preserve ^ range",
      "specifierTypes": ["range"],
      "range": "^"
    },
    {
      "label": "Preserve exact version",
      "specifierTypes": ["exact"],
      "range": ""
    }
  ]
}